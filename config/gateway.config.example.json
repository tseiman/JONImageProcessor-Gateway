{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "corsAllowedOrigins": []
  },
  "auth": {
    "tokenEnv": "JON_GATEWAY_TOKEN",
    "tokenSha256": [],
    "allowQueryToken": true
  },
  "jonImageProcessor": {
    "ipcSocket": "/tmp/jonimageprocessor.sock",
    "requestTimeoutMs": 2000
  },
  "files": {
    "maxUploadBytes": 52428800,
    "roots": {
      "backgrounds": {
        "path": "/opt/JONImageProcessor/backgrounds",
        "allowUpload": true,
        "allowDelete": true,
        "allowedExtensions": [".zip"],
        "ipcKey": "background.image"
      },
      "pause": {
        "path": "/opt/JONImageProcessor/pause",
        "allowUpload": true,
        "allowDelete": true,
        "allowedExtensions": [".zip"],
        "ipcKey": "pause.image"
      }
    }
  },
  "api": {
    "commands": {
      "list": { "enabled": true },
      "get": {
        "enabled": true,
        "keys": [
          "benchmark",
          "camera.enabled",
          "pause.enabled",
          "pause.image",
          "pause.folder",
          "pause.loopIfVideo",
          "pause.showStatusText",
          "pause.textColor",
          "pause.textPosition",
          "pause.textSize",
          "pause.font",
          "segmentation.threshold",
          "segmentation.smoothing",
          "segmentation.morphology",
          "background.effect",
          "background.image",
          "background.folder",
          "background.loopIfVideo",
          "background.overlayColor",
          "background.overlayAlpha",
          "background.blurStrength",
          "runtime.noMask",
          "runtime.noOverlay"
        ]
      },
      "set": {
        "enabled": true,
        "items": {
          "camera.enabled": { "type": "boolean" },
          "pause.enabled": { "type": "boolean" },
          "pause.image": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$", "maxLength": 120, "assetRoot": "pause" },
          "pause.loopIfVideo": { "type": "boolean" },
          "pause.showStatusText": { "type": "boolean" },
          "pause.textColor": { "type": "string", "pattern": "^[0-9a-fA-F]{8}$" },
          "pause.textPosition": { "type": "string", "pattern": "^(auto|[0-9]+x[0-9]+)$" },
          "pause.textSize": { "type": "number", "min": 0.1, "max": 10.0 },
          "pause.font": { "type": "string", "enum": ["plain", "simplex", "duplex", "complex", "triplex", "complex-small", "script-simplex", "script-complex"] },
          "segmentation.threshold": { "type": "number", "min": 0, "max": 1 },
          "segmentation.smoothing": { "type": "number", "min": 0, "max": 1 },
          "segmentation.morphology": { "type": "string", "enum": ["off", "light", "strong"] },
          "background.effect": { "type": "string", "enum": ["none", "color", "blur", "image"] },
          "background.image": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$", "maxLength": 120, "assetRoot": "backgrounds" },
          "background.loopIfVideo": { "type": "boolean" },
          "background.overlayColor": { "type": "string", "pattern": "^([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]),([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]),([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$" },
          "background.overlayAlpha": { "type": "number", "min": 0, "max": 1 },
          "background.blurStrength": { "type": "integer", "min": 1, "max": 100 },
          "runtime.noMask": { "type": "boolean" },
          "runtime.noOverlay": { "type": "boolean" }
        }
      }
    }
  }
}
