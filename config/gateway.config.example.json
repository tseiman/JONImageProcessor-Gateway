{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "corsAllowedOrigins": []
  },
  "auth": {
    "tokenEnv": "JON_GATEWAY_TOKEN",
    "tokenSha256": [],
    "allowQueryToken": true
  },
  "jonImageProcessor": {
    "ipcSocket": "/tmp/jonimageprocessor.sock",
    "requestTimeoutMs": 2000,
    "pollIntervalMs": 1000
  },
  "files": {
    "maxUploadBytes": 52428800,
    "roots": {
      "backgrounds": {
        "path": "/opt/JONImageProcessor/var/userdata/background",
        "allowUpload": true,
        "allowDelete": true,
        "allowedExtensions": [".zip"],
        "ipcKey": "background.image"
      },
      "pause": {
        "path": "/opt/JONImageProcessor/var/userdata/pause",
        "allowUpload": true,
        "allowDelete": true,
        "allowedExtensions": [".zip"],
        "ipcKey": "pause.image"
      },
      "fonts": {
        "path": "/opt/JONImageProcessor/var/userdata/fonts",
        "kind": "file",
        "fileType": "TTF Font",
        "allowUpload": true,
        "allowDelete": true,
        "allowedExtensions": [".ttf"]
      }
    }
  },
  "api": {
    "commands": {
      "list": { "enabled": true },
      "get": {
        "enabled": true,
        "keys": [
          "benchmark",
          "camera.enabled",
          "pause.enabled",
          "pause.image",
          "pause.folder",
          "pause.loopIfVideo",
          "pause.showStatusText",
          "pause.textColor",
          "pause.textPosition",
          "pause.textSize",
          "pause.font",
          "pause.fontDirectory",
          "pause.fontAlign",
          "segmentation.threshold",
          "segmentation.smoothing",
          "segmentation.morphology",
          "runtime.noOverlay",
          "background.effect",
          "background.blurStrength",
          "background.image",
          "background.folder",
          "background.overlayColor",
          "background.overlayAlpha",
          "background.loopIfVideo",
          "runtime.noMask"
        ]
      },
      "set": {
        "enabled": true,
        "items": {
          "camera.enabled": { "type": "boolean" },
          "pause.enabled": { "type": "boolean" },
          "pause.image": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$", "maxLength": 120, "assetRoot": "pause" },
          "pause.loopIfVideo": { "type": "boolean" },
          "pause.showStatusText": { "type": "boolean" },
          "pause.textColor": { "type": "string", "pattern": "^[0-9a-fA-F]{8}$" },
          "pause.textPosition": {
            "type": "string",
            "pattern": "^(auto|[0-9]+x[0-9]+)$",
            "ui": {
              "position": {
                "x": { "min": 0, "max": 1920, "step": 10 },
                "y": { "min": 0, "max": 1080, "step": 10 }
              }
            }
          },
          "pause.textSize": { "type": "number", "min": 0.1, "max": 10.0 },
          "pause.font": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$",
            "maxLength": 120,
            "ui": {
              "builtinFonts": ["plain", "simplex", "duplex", "complex", "triplex", "complex-small", "script-simplex", "script-complex"],
              "fontRoot": "fonts"
            }
          },
          "pause.fontAlign": { "type": "string", "enum": ["left", "center", "right"] },
          "segmentation.threshold": { "type": "number", "min": 0, "max": 1, "step": 0.001 },
          "segmentation.smoothing": { "type": "number", "min": 0, "max": 1 },
          "segmentation.morphology": { "type": "string", "enum": ["off", "light", "strong"] },
          "background.effect": { "type": "string", "enum": ["none", "color", "blur", "image"], "ui": { "section": "background", "order": 20 } },
          "background.image": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$", "maxLength": 120, "assetRoot": "backgrounds", "ui": { "section": "background", "order": 40 } },
          "background.loopIfVideo": { "type": "boolean", "ui": { "section": "background", "order": 60 } },
          "background.overlayColor": { "type": "string", "pattern": "^([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]),([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5]),([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$", "ui": { "section": "background", "order": 50, "combinedWith": "background.overlayAlpha" } },
          "background.overlayAlpha": { "type": "number", "min": 0, "max": 1, "ui": { "section": "background", "order": 51, "hidden": true, "combinedWith": "background.overlayColor" } },
          "background.blurStrength": { "type": "integer", "min": 1, "max": 100, "ui": { "section": "background", "order": 30 } },
          "runtime.noMask": { "type": "boolean" },
          "runtime.noOverlay": { "type": "boolean", "ui": { "section": "background", "order": 10, "label": "Enable Background" } }
        }
      }
    }
  }
}
